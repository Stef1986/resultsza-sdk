# Copy this file to .env and fill in your own key.
# .env is git-ignored - never commit a real key.
# Get an API key at https://resultsza.co.za/generate_api_key
RESULTSZA_API_KEY=your_api_key_here

# Only needed if you run the webhook receiver example.
# This is the secret shown in your portal Push Settings.
RESULTSZA_WEBHOOK_SECRET=your_webhook_secret_here
